pipeline {
    agent any
    
    stages {
        stage('Maven installation') {
            steps {
                sh 'sudo dnf install maven -y'
            }
        }
        
        stage('Build Package') {
            steps {
                sh 'mvn clean package'
            }
        }
        
        stage('Release') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar'
            }
        }
    }
}
